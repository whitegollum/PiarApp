# Configuración de la Aplicación
APP_NAME=PiarAPP - Gestión de Clubs de Aeromodelismo
APP_VERSION=0.1.0
DEBUG=True

# Base de Datos
DATABASE_URL=sqlite:///./data/piar.db
# Para PostgreSQL: postgresql://user:password@localhost/piar

# Seguridad
SECRET_KEY=tu-clave-secreta-aqui-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
INVITATION_TOKEN_EXPIRY_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Email (SMTP)
# Dejar vacío para desarrollo (los emails se mostrarán en consola)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-contraseña-app
SMTP_SENDER=noreply@piarapp.com
SMTP_SENDER_NAME=PiarAPP
SMTP_USE_TLS=True

# Frontend
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# 2FA
TWO_FACTOR_ENABLED=False

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173"]

# Rutas de archivos
UPLOAD_FOLDER=./uploads
MAX_UPLOAD_SIZE=5242880

# Autenticación. Por defecto 2FA desactivado
TWO_FACTOR_ENABLED=False

# OpenClaw
# La URL base para la conexión. Si empieza por http/s se convertirá automáticamente a ws/wss.
# Ejemplo: http://TU-IP-ABASURA:18789/v1/chat -> ws://TU-IP-ABASURA:18789
OPENCLAW_API_KEY=tu-api-key-aqui
OPENCLAW_API_URL=http://localhost:18789/v1/chat
# Modo de autenticación: "password" (requerido para gateway-client) o "api_key"
OPENCLAW_AUTH_MODE=password
# Usuario no utilizado en modo gateway-client (id forzado a "gateway-client")
# OPENCLAW_USERNAME=
OPENCLAW_PASSWORD=tu-password-aqui
# URL de login (opcional, uso futuro)
OPENCLAW_LOGIN_URL=http://localhost:18789/v1/login
